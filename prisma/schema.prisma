generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum AccountType {
  EVALUATION
  PA
  FUNDED
}

enum AccountStatus {
  ACTIVE
  PASSED
  FAILED
  CLOSED
  ARCHIVED
}

enum ExpenseType {
  PURCHASE
  RESET
  SUBSCRIPTION
  ACTIVATION
  OTHER
}

enum PayoutStatus {
  PENDING
  PAID
  CANCELLED
}

model User {
  id          String           @id @default(cuid())
  email       String           @unique
  name        String
  role        UserRole         @default(USER)
  googleId    String?          @unique
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  accounts    Account[]
  tradingDays TradingDay[]
  expenses    AccountExpense[]
  payouts     Payout[]

  @@index([role])
  @@index([isActive])
}

model PropFirm {
  id        String         @id @default(cuid())
  name      String         @unique
  website   String?
  notes     String?
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  rules     PropFirmRule[]
  accounts  Account[]

  @@index([isActive])
}

model PropFirmRule {
  id                   String      @id @default(cuid())
  propFirmId           String
  name                 String
  accountType          AccountType
  accountSize          Decimal     @db.Decimal(12, 2)
  target               Decimal     @db.Decimal(12, 2)
  maxDrawdown          Decimal     @db.Decimal(12, 2)
  dailyDrawdown        Decimal?    @db.Decimal(12, 2)
  buffer               Decimal?    @db.Decimal(12, 2)
  consistencyPercent   Decimal?    @db.Decimal(5, 2)
  minTradingDays       Int?
  defaultPurchasePrice Decimal?    @db.Decimal(12, 2)
  defaultResetPrice    Decimal?    @db.Decimal(12, 2)
  notes                String?
  isActive             Boolean     @default(true)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  propFirm             PropFirm    @relation(fields: [propFirmId], references: [id], onDelete: Restrict)
  accounts             Account[]

  @@index([propFirmId])
  @@index([accountType])
  @@index([isActive])
}

model Account {
  id             String           @id @default(cuid())
  userId         String
  propFirmId     String
  propFirmRuleId String?
  name           String
  accountType    AccountType
  accountSize    Decimal          @db.Decimal(12, 2)
  status         AccountStatus    @default(ACTIVE)
  purchaseDate   DateTime?
  purchasePrice  Decimal?         @db.Decimal(12, 2)
  activationDate DateTime?
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  propFirm       PropFirm         @relation(fields: [propFirmId], references: [id], onDelete: Restrict)
  propFirmRule   PropFirmRule?    @relation(fields: [propFirmRuleId], references: [id], onDelete: SetNull)
  tradingDays    TradingDay[]
  expenses       AccountExpense[]
  payouts        Payout[]

  @@index([userId])
  @@index([propFirmId])
  @@index([propFirmRuleId])
  @@index([status])
  @@index([accountType])
}

model TradingDay {
  id         String   @id @default(cuid())
  userId     String
  accountId  String
  tradeDate  DateTime @db.Date
  profitLoss Decimal  @db.Decimal(12, 2)
  tradeCount Int?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, tradeDate])
  @@index([userId])
  @@index([tradeDate])
}

model AccountExpense {
  id          String      @id @default(cuid())
  userId      String
  accountId   String
  type        ExpenseType
  amount      Decimal     @db.Decimal(12, 2)
  expenseDate DateTime    @db.Date
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  account     Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([accountId])
  @@index([expenseDate])
  @@index([type])
}

model Payout {
  id         String       @id @default(cuid())
  userId     String
  accountId  String
  amount     Decimal      @db.Decimal(12, 2)
  payoutDate DateTime     @db.Date
  status     PayoutStatus @default(PENDING)
  notes      String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  account    Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([accountId])
  @@index([payoutDate])
  @@index([status])
}
